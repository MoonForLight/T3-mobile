<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header / Toolbar Simulation -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#3F51B5" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:text="Form Identitas Mahasiswa"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Like Container for Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp">

                <!-- Label Nama -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Lengkap"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <EditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan nama..."
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp" />

                <!-- Label Gender -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jenis Kelamin"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="16dp"/>

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbLaki"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laki-laki"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rbPerempuan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perempuan"
                        android:layout_marginStart="16dp"
                        android:textSize="14sp" />
                </RadioGroup>

                <!-- Label Hobi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hobi"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="16dp"/>

                <CheckBox
                    android:id="@+id/cbMembaca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Membaca"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/cbCoding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coding"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/cbOlahraga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Olahraga"
                    android:textSize="14sp" />

                <!-- Button -->
                <Button
                    android:id="@+id/btnTampil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tampilkan"
                    android:textAllCaps="false"
                    android:backgroundTint="#3F51B5"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="24dp"/>

            </LinearLayout>

            <!-- Output Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:elevation="2dp"
                android:minHeight="100dp">

                <TextView
                    android:id="@+id/tvHasil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hasil akan muncul di sini..."
                    android:textColor="#3F51B5"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
